# API + Prisma (copy to .env in repo root and packages/db/.env for Prisma CLI)
DATABASE_URL="postgresql://ascension:ascension@localhost:5432/ascension?schema=public"

# Optional: Ascension API
PORT=4000
CORS_ORIGIN="http://localhost:3000"

# Storefront (apps/web) — optional
