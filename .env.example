# ==========================================
# ASCENSION PLATFORM ENVIRONMENT VARIABLES
# ==========================================

# 1. Database Configuration
# Prisma URL format: postgresql://[user]:[password]@[host]:[port]/[db_name]
DATABASE_URL="postgresql://username:password@localhost:5432/ascension_db"

# 2. Server Configuration
PORT=5000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"

# 3. JWT Configuration (Authentication)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
SESSION_SECRET="your-session-secret-key"
BCRYPT_ROUNDS=12

# 4. Email Configuration (NodeMailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password-here"
SMTP_FROM="noreply@yourdomain.com"

# 5. File Upload / Cloudinary Configuration
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/webp"

CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# 6. Razorpay Configuration (Payments)
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_secret_key"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# 7. Security & Rate Limiting
ALLOWED_ORIGINS="https://ascension.com,https://www.ascension.com"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 8. Admin Configuration (Initial DB Seeding / Checks)
ADMIN_EMAIL="admin@ascension.com"
ADMIN_PASSWORD="admin123"

# 9. Storefront Configuration (apps/web)
NEXT_PUBLIC_BUSINESS_ADDRESS="Your street, Phagwara, Punjab, India"
NEXT_PUBLIC_CONTACT_EMAIL="hello@example.com"
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL="https://www.google.com/maps/embed?pb=..."
